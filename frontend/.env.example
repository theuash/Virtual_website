# ─── API ──────────────────────────────────────────────────────────────────────
# Backend REST API base URL
VITE_API_URL=http://localhost:5001/api

# ─── Messaging Server ─────────────────────────────────────────────────────────
# Real-time messaging server URL
VITE_MESSAGING_URL=http://localhost:4001

# ─── Supabase (OTP Authentication) ────────────────────────────────────────────
# Get from: https://supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# IMPORTANT: Must match GOOGLE_CLIENT_ID in backend .env
# IMPORTANT: Add these URIs to your Google OAuth app's "Authorized JavaScript origins":
#   - http://localhost:5173
#   - http://localhost:3000
#   - https://your-app.netlify.app
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
