# --- API ---
# Backend REST API base URL
VITE_API_URL=http://localhost:5001/api

# --- Messaging Server ---
# Real-time messaging server URL
VITE_MESSAGING_URL=http://localhost:4001

# --- Google OAuth ---
# Get from: https://console.cloud.google.com -> APIs & Services -> Credentials
# IMPORTANT: Must match GOOGLE_CLIENT_ID in backend .env
# IMPORTANT: Add these URIs to your Google OAuth app's "Authorized JavaScript origins":
#   - http://localhost:5173
#   - http://localhost:3000
#   - https://your-app.netlify.app
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# --- remove.bg (Avatar background removal) ---
# Get from: https://www.remove.bg/api -> Dashboard -> API Keys
VITE_REMOVE_BG_API_KEY=your_remove_bg_api_key_here

# --- ipstack (IP-based country detection) ---
# Get from: https://ipstack.com -> Dashboard -> API Access Key
VITE_IPSTACK_API_KEY=your_ipstack_api_key_here
