# ── Messaging Server — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values.

# MongoDB — same URI as main backend, messaging uses its own collections
MONGODB_URI=mongodb://localhost:27017/virtual

# Upstash Redis (free tier) — get from https://upstash.com
# Format: rediss://:<password>@<host>:<port>
REDIS_URL=rediss://:your_password@your-upstash-host.upstash.io:6380

# Frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# Shared secret between messaging server and main backend
# Must match INTERNAL_SECRET in the main backend's .env
INTERNAL_SECRET=change_this_to_a_long_random_string

# JWT secret — MUST be identical to the main backend's JWT_SECRET
# so the same user tokens work on both servers
JWT_SECRET=VIRTUAL_Super_Secret_Key_Management_12_Main_Ujwal_2004

# Port this server listens on (main backend is on 5001)
PORT=4001
