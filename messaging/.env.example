# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4001

# ─── Database ─────────────────────────────────────────────────────────────────
# Same MongoDB Atlas URI as the main backend
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/virtual?retryWrites=true&w=majority&appName=Cluster0

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must match JWT_SECRET in the main backend .env exactly
JWT_SECRET=your_jwt_secret_here

# ─── Internal Secret ──────────────────────────────────────────────────────────
# Must match INTERNAL_SECRET in the main backend .env exactly
INTERNAL_SECRET=your_internal_secret_here

# ─── Redis ────────────────────────────────────────────────────────────────────
# Get a free Redis instance from https://upstash.com
REDIS_URL=rediss://default:<password>@your-db.upstash.io:6379

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your deployed frontend URL
FRONTEND_URL=https://your-app.netlify.app
