# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development                        # development | production

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/virtual?retryWrites=true&w=majority&appName=Cluster0

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# Use long random strings — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (local + deployed)
CLIENT_URL=http://localhost:5173,https://your-app.netlify.app

# ─── Messaging Server ─────────────────────────────────────────────────────────
MESSAGING_URL=http://localhost:4001
INTERNAL_SECRET=your_internal_secret_here  # Shared secret between backend and messaging server

# ─── Email OTP ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password   # Use Gmail App Password, not your real password
SMTP_FROM=your_gmail@gmail.com

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# IMPORTANT: Add these URIs to your Google OAuth app's "Authorized redirect URIs":
#   - http://localhost:5173
#   - http://localhost:3000
#   - https://your-app.netlify.app
#   - https://your-app.netlify.app/auth/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── IP Geolocation ──────────────────────────────────────────────────────────
# ipstack — IP geolocation (key stays server-side, never exposed to frontend)
IPSTACK_API_KEY=your_ipstack_api_key_here
