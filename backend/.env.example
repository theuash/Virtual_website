# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development                        # development | production

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/virtual?retryWrites=true&w=majority&appName=Cluster0

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# Use long random strings — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173           # Frontend URL

# ─── Messaging Server ─────────────────────────────────────────────────────────
MESSAGING_URL=http://localhost:4001
INTERNAL_SECRET=your_internal_secret_here  # Shared secret between backend and messaging server

# ─── Supabase (OTP Authentication) ────────────────────────────────────────────
# Get from: https://supabase.com → Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# SKIP_SUPABASE_OTP=true                   # Uncomment to bypass OTP during testing

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── WhatsApp OTP (Optional) ──────────────────────────────────────────────────
# Uncomment to enable WhatsApp-based OTP delivery
# PYTHON_BIN=python
# WHATSAPP_CLIENT_ID=virtual-otp
# WHATSAPP_SESSION_PATH=.wwebjs_auth
# WHATSAPP_HEADLESS=true
